# Copy to .env.local and fill in your values.
# These are build-time env vars — never use server-side secrets here.
# The actual Supabase service_role and Gemini key live ONLY in Edge Function env vars.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
