{
  "version": "1.0",
  "operation": "select",
  "table": "tareas",
  "columns": ["id", "titulo", "estado", "creado_en"],
  "filters": [
    { "column": "estado", "op": "in", "value": ["activa", "pendiente"] },
    { "column": "titulo", "op": "ilike", "value": "%urgente%" },
    { "column": "completada_en", "op": "is_null" }
  ],
  "order_by": [
    { "column": "creado_en", "dir": "asc" }
  ],
  "limit": 50
}
